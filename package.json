{
  "name": "local-port-bridge-workspace",
  "private": true,
  "version": "0.5.260709",
  "license": "MIT",
  "packageManager": "pnpm@11.10.0",
  "engines": {
    "npm": "please-use-pnpm"
  },
  "scripts": {
    "compile": "pnpm -r --filter './extensions/*' run compile",
    "watch": "pnpm -r --parallel --filter './extensions/*' run watch",
    "typecheck": "pnpm -r --filter './extensions/*' run typecheck",
    "package": "pnpm -r --filter './extensions/*' run package"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "@vscode/vsce-sign",
      "keytar"
    ]
  }
}
