{
  "name": "port-bridge-remote",
  "displayName": "Port Bridge Remote",
  "description": "%extension.description%",
  "version": "0.11.260709",
  "publisher": "lwmacct",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lwmacct/260708-port-bridge"
  },
  "homepage": "https://github.com/lwmacct/260708-port-bridge#readme",
  "bugs": {
    "url": "https://github.com/lwmacct/260708-port-bridge/issues"
  },
  "qna": "https://github.com/lwmacct/260708-port-bridge/issues",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/actions/workflow/status/lwmacct/260708-port-bridge/ci.yml?branch=main&label=ci",
      "href": "https://github.com/lwmacct/260708-port-bridge/actions/workflows/ci.yml",
      "description": "CI status"
    },
    {
      "url": "https://img.shields.io/github/license/lwmacct/260708-port-bridge",
      "href": "https://github.com/lwmacct/260708-port-bridge/blob/main/LICENSE",
      "description": "License"
    }
  ],
  "preview": false,
  "pricing": "Free",
  "keywords": [
    "port-forwarding",
    "remote-development",
    "tunnel",
    "vscode-remote"
  ],
  "engines": {
    "vscode": "^1.128.0",
    "npm": "please-use-pnpm"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "portBridge.remote.start",
        "title": "%commands.start.title%"
      },
      {
        "command": "portBridge.remote.stop",
        "title": "%commands.stop.title%"
      },
      {
        "command": "portBridge.remote.restart",
        "title": "%commands.restart.title%"
      },
      {
        "command": "portBridge.remote.reconnectControl",
        "title": "%commands.reconnectControl.title%"
      },
      {
        "command": "portBridge.remote.showStatus",
        "title": "%commands.showRemoteStatus.title%"
      }
    ],
    "configuration": {
      "title": "Port Bridge",
      "properties": {
        "portBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoStart.description%"
        },
        "portBridge.mappings": {
          "type": "array",
          "default": [],
          "description": "%configuration.mappings.description%",
          "items": {
            "type": "object",
            "anyOf": [
              {
                "required": [
                  "port"
                ]
              },
              {
                "required": [
                  "localPort"
                ]
              }
            ],
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.mapping.enabled.description%"
              },
              "name": {
                "type": "string",
                "description": "%configuration.mapping.name.description%"
              },
              "port": {
                "type": "number",
                "minimum": 1,
                "maximum": 65535,
                "description": "%configuration.mapping.port.description%"
              },
              "localHost": {
                "type": "string",
                "default": "127.0.0.1",
                "description": "%configuration.mapping.localHost.description%"
              },
              "localPort": {
                "type": "number",
                "minimum": 1,
                "maximum": 65535,
                "description": "%configuration.mapping.localPort.description%"
              },
              "remoteSocket": {
                "type": "string",
                "description": "%configuration.mapping.remoteSocket.description%"
              },
              "remoteHost": {
                "type": "string",
                "default": "127.0.0.1",
                "description": "%configuration.mapping.remoteHost.description%"
              },
              "remotePort": {
                "type": "number",
                "minimum": 1,
                "maximum": 65535,
                "description": "%configuration.mapping.remotePort.description%"
              }
            }
          }
        },
        "portBridge.controlReconnectDelayMs": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 30000,
          "description": "%configuration.controlReconnectDelayMs.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "typecheck": "tsc -p . --noEmit"
  }
}
