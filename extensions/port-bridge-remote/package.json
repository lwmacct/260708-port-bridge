{
  "name": "port-bridge-remote",
  "displayName": "Port Bridge Remote",
  "description": "Remote-side endpoint for Port Bridge.",
  "version": "0.9.260709",
  "publisher": "lwmacct",
  "license": "MIT",
  "engines": {
    "vscode": "^1.128.0",
    "npm": "please-use-pnpm"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "portBridge.remote.start",
        "title": "Port Bridge: Start Remote"
      },
      {
        "command": "portBridge.remote.stop",
        "title": "Port Bridge: Stop Remote"
      },
      {
        "command": "portBridge.remote.restart",
        "title": "Port Bridge: Restart Remote"
      },
      {
        "command": "portBridge.remote.reconnectControl",
        "title": "Port Bridge: Reconnect Control Channel"
      },
      {
        "command": "portBridge.remote.showStatus",
        "title": "Port Bridge: Show Remote Status"
      }
    ],
    "configuration": {
      "title": "Port Bridge",
      "properties": {
        "portBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start configured port bridges automatically in remote windows."
        },
        "portBridge.mappings": {
          "type": "array",
          "default": [],
          "description": "Local-to-remote port mappings. Use a number for the common case, or an object for advanced overrides.",
          "items": {
            "anyOf": [
              {
                "type": "number",
                "minimum": 1,
                "maximum": 65535,
                "description": "Port to expose with default local/remote hosts and socket path."
              },
              {
                "type": "object",
                "anyOf": [
                  {
                    "required": [
                      "port"
                    ]
                  },
                  {
                    "required": [
                      "localPort"
                    ]
                  }
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Stable mapping name. Defaults to port-<localPort>."
                  },
                  "port": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 65535,
                    "description": "Port to use for both localPort and remotePort unless they are explicitly set."
                  },
                  "localHost": {
                    "type": "string",
                    "default": "127.0.0.1",
                    "description": "Host on the local machine to connect to."
                  },
                  "localPort": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 65535,
                    "description": "Port on the local machine to connect to."
                  },
                  "remoteSocket": {
                    "type": "string",
                    "description": "Unix socket path to create in the remote workspace. Defaults to /tmp/vscode-port-bridge/<name>.sock."
                  },
                  "remoteHost": {
                    "type": "string",
                    "default": "127.0.0.1",
                    "description": "Remote host/interface for the TCP listener."
                  },
                  "remotePort": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 65535,
                    "description": "TCP port to listen on in the remote workspace."
                  }
                }
              }
            ]
          }
        },
        "portBridge.controlReconnectDelayMs": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 30000,
          "description": "Delay before recreating the internal control tunnel after it is closed."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "typecheck": "tsc -p . --noEmit"
  }
}
