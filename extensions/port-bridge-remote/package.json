{
  "name": "port-bridge-remote",
  "displayName": "Port Bridge Remote",
  "description": "Remote-side endpoint for Local Port Bridge.",
  "version": "0.4.260708",
  "publisher": "lwmacct",
  "license": "MIT",
  "engines": {
    "vscode": "^1.128.0",
    "npm": "please-use-pnpm"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "localPortBridge.remote.start",
        "title": "Local Port Bridge: Start Remote"
      },
      {
        "command": "localPortBridge.remote.stop",
        "title": "Local Port Bridge: Stop Remote"
      },
      {
        "command": "localPortBridge.remote.restart",
        "title": "Local Port Bridge: Restart Remote"
      },
      {
        "command": "localPortBridge.remote.showStatus",
        "title": "Local Port Bridge: Show Remote Status"
      }
    ],
    "configuration": {
      "title": "Local Port Bridge",
      "properties": {
        "localPortBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start configured local port bridges automatically in remote windows."
        },
        "localPortBridge.mappings": {
          "type": "array",
          "default": [],
          "description": "Local-to-remote port mappings.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "localPort"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Stable mapping name."
              },
              "localHost": {
                "type": "string",
                "default": "127.0.0.1",
                "description": "Host on the local machine to connect to."
              },
              "localPort": {
                "type": "number",
                "minimum": 1,
                "maximum": 65535,
                "description": "Port on the local machine to connect to."
              },
              "remoteSocket": {
                "type": "string",
                "description": "Unix socket path to create in the remote workspace."
              },
              "remoteHost": {
                "type": "string",
                "default": "127.0.0.1",
                "description": "Remote host/interface for the optional TCP listener."
              },
              "remotePort": {
                "type": "number",
                "minimum": 1,
                "maximum": 65535,
                "description": "Optional TCP port to listen on in the remote workspace."
              }
            }
          }
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "typecheck": "tsc -p . --noEmit",
    "package": "pnpm run compile && vsce package --allow-missing-repository --out ../../port-bridge-remote-0.4.260708.vsix"
  }
}
