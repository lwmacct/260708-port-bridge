{
  "name": "port-bridge-local",
  "displayName": "Port Bridge Local",
  "description": "Local-side endpoint for Port Bridge.",
  "version": "0.8.260709",
  "publisher": "lwmacct",
  "license": "MIT",
  "engines": {
    "vscode": "^1.128.0",
    "npm": "please-use-pnpm"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:portBridge.local.connectControl"
  ],
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "portBridge.local.showStatus",
        "title": "Port Bridge: Show Local Status"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "typecheck": "tsc -p . --noEmit"
  }
}
