{
  "name": "portrelay-remote",
  "displayName": "Port Relay Remote",
  "description": "%extension.description%",
  "version": "0.14.260710",
  "publisher": "lwmacct",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lwmacct/260708-portrelay"
  },
  "homepage": "https://github.com/lwmacct/260708-portrelay#readme",
  "bugs": {
    "url": "https://github.com/lwmacct/260708-portrelay/issues"
  },
  "qna": "https://github.com/lwmacct/260708-portrelay/issues",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/actions/workflow/status/lwmacct/260708-portrelay/ci.yml?branch=main&label=ci",
      "href": "https://github.com/lwmacct/260708-portrelay/actions/workflows/ci.yml",
      "description": "CI status"
    },
    {
      "url": "https://img.shields.io/github/license/lwmacct/260708-portrelay",
      "href": "https://github.com/lwmacct/260708-portrelay/blob/main/LICENSE",
      "description": "License"
    }
  ],
  "preview": false,
  "pricing": "Free",
  "keywords": [
    "port",
    "relay",
    "port-relay",
    "portrelay",
    "port-forwarding",
    "reverse-port-forwarding",
    "reverse-tunnel",
    "local-port",
    "localhost",
    "endpoint",
    "tcp",
    "socket",
    "unix-socket",
    "remote",
    "remote-development",
    "remote-ssh",
    "dev-container",
    "dev-containers",
    "tunnel",
    "vscode-remote",
    "chrome",
    "chromium",
    "cdp",
    "playwright"
  ],
  "engines": {
    "vscode": "^1.128.0",
    "npm": "please-use-pnpm"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "commands": [
      {
        "command": "portrelay.remote.start",
        "title": "%commands.start.title%"
      },
      {
        "command": "portrelay.remote.stop",
        "title": "%commands.stop.title%"
      },
      {
        "command": "portrelay.remote.restart",
        "title": "%commands.restart.title%"
      },
      {
        "command": "portrelay.remote.reconnectControl",
        "title": "%commands.reconnectControl.title%"
      },
      {
        "command": "portrelay.remote.showStatus",
        "title": "%commands.showRemoteStatus.title%"
      }
    ],
    "configuration": {
      "title": "Port Relay",
      "properties": {
        "portrelay.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.autoStart.description%"
        },
        "portrelay.mappings": {
          "type": "array",
          "default": [],
          "description": "%configuration.mappings.description%",
          "items": {
            "type": "object",
            "required": [
              "local",
              "remote"
            ],
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true,
                "description": "%configuration.mapping.enabled.description%"
              },
              "name": {
                "type": "string",
                "description": "%configuration.mapping.name.description%"
              },
              "local": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string"
                    }
                  }
                ],
                "description": "%configuration.mapping.local.description%"
              },
              "remote": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string"
                    }
                  }
                ],
                "description": "%configuration.mapping.remote.description%"
              }
            }
          }
        },
        "portrelay.controlReconnectDelayMs": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 30000,
          "description": "%configuration.controlReconnectDelayMs.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -watch -p .",
    "typecheck": "tsc -p . --noEmit"
  }
}
